{% extends 'base.html.twig' %}

{% block body %}
    <div class="content">


        <h2>Wish details : {{ wish.title }}</h2>
        <p>Creation date: {{ wish.dateCreated | date('d/m/Y H:i:s') }}</p>
        {% if wish.dateUpdated !== null %}
        <p>Update date: {{ wish.dateUpdated | date('d/m/Y H:i:s') }}</p>
        {%endif %}
        <p>Author: {{ wish.author }}</p>
        <p>Publication state:
            {%if wish.published === 0 %}
                <span>not published</span>
            {% else  %}
                <span>published</span>
            {% endif %}
        </p>
        <p>Description: {{ wish.description }}</p>
        <p>Category: {{ category.name }}</p>
        <br>
        <div class="buttons">
            <button class="removeButton">
                <a  href="{{ path('wish_update',{ 'id': wish.id}) }}">Update your wish</a>
            </button>
            <button class="removeButton" type="submit" onclick="return confirm('are you sure you want to remove your dream?') ">Remove your wish</button>

        </div>

    </div>


{% endblock %}

{% block extrastyle %}
    <style>
        body{

            background-image: url('{{ asset('images/7023263.jpg') }}'), linear-gradient(rgba(255, 255, 255, 08), rgba(255, 255, 255, 0.6)) ;
        }
        footer{
            margin-top: 10vh;
            background: linear-gradient(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.6));
            border-radius: 4px;
            padding:4px;
        }
    </style>
{% endblock %}
