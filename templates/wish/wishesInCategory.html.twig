{% extends 'base.html.twig' %}

{% block extrastyle %}
    <style>
        body{

            background-image: url('{{ asset('images/7023263.jpg') }}'), linear-gradient(rgba(255, 255, 255, 08), rgba(255, 255, 255, 0.6)) ;
        }
        footer{
            margin-top: 10vh;
            background: linear-gradient(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.6));
            border-radius: 4px;
            padding:4px;
        }
    </style>

{% endblock %}

{% block body %}

    <div class="content">
        <h2>Wishes in categories</h2>
        <section>
            {% for category in categories %}
                <article>
                    <a href="{{ path('wish_categories_wishes', {'id':category.id}) }}">
                        <h4>{{ category.name }}</h4>
                    </a>

                </article>
            {% endfor %}
        </section>
    </div>

{% endblock %}

